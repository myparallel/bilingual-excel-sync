# EditorConfig is awesome: https://EditorConfig.org

# top-most EditorConfig file
root = true

# Unix-style newlines with a newline ending every file
[*]
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# Set default charset
[*.{py,pyw}]
charset = utf-8

# 4 space indentation
[*.py]
indent_style = space
indent_size = 4

# Tab indentation (no size specification)
[Makefile]
indent_style = tab

# Indentation override for all JS/TS files
[*.{js,jsx,ts,tsx}]
indent_style = space
indent_size = 2

# Indentation override for all CSS files
[*.{css,scss}]
indent_style = space
indent_size = 2

# Indentation override for all HTML files
[*.{html,htm}]
indent_style = space
indent_size = 2

# Indentation override for all JSON files
[*.json]
indent_style = space
indent_size = 2

# Indentation override for all YAML files
[*.{yml,yaml}]
indent_style = space
indent_size = 2

# Indentation override for all Markdown files
[*.md]
indent_style = space
indent_size = 2

# Indentation override for all TOML files
[*.toml]
indent_style = space
indent_size = 2

# Indentation override for all INI files
[*.{ini,cfg}]
indent_style = space
indent_size = 4

# Indentation override for all shell scripts
[*.{sh,bash}]
indent_style = space
indent_size = 2

# Indentation override for all PowerShell scripts
[*.{ps1,psm1}]
indent_style = space
indent_size = 4

# Indentation override for all batch scripts
[*.{bat,cmd}]
indent_style = space
indent_size = 4

# Indentation override for all SQL files
[*.sql]
indent_style = space
indent_size = 4

# Indentation override for all XML files
[*.xml]
indent_style = space
indent_size = 2

# Indentation override for all config files
[*.{conf,config}]
indent_style = space
indent_size = 4

# Indentation override for all text files
[*.txt]
indent_style = space
indent_size = 4

# Indentation override for all log files
[*.log]
indent_style = space
indent_size = 4

# Indentation override for all Excel files
[*.{xlsx,xlsm,xls}]
indent_style = space
indent_size = 4

# Indentation override for all Word files
[*.{docx,doc}]
indent_style = space
indent_size = 4

# Indentation override for all PowerPoint files
[*.{pptx,ppt}]
indent_style = space
indent_size = 4

# Indentation override for all PDF files
