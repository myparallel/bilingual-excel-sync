indent_style = space
indent_size = 4

# Indentation override for all image files
[*.{png,jpg,jpeg,gif,svg,ico}]
indent_style = space
indent_size = 4

# Indentation override for all font files
[*.{ttf,otf,woff,woff2}]
indent_style = space
indent_size = 4

# Indentation override for all archive files
[*.{zip,tar,gz,rar,7z}]
